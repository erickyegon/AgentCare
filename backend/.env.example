# ============================================================================
# AgentCare backend configuration — copy to `.env` and fill in real values.
# The real `.env` is gitignored. NEVER commit real secrets or patient data.
# ============================================================================

# ---- Application ----
APP_NAME=AgentCare
ENVIRONMENT=development            # development | production
DEBUG=true
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed frontend origins (CORS).
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Security (JWT) ----
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720
JWT_ALGORITHM=HS256

# ---- Database ----
# SQLite (zero-config local dev):
DATABASE_URL=sqlite:///./agentcare.db
# PostgreSQL (production / docker-compose) — the compose file sets this automatically:
# DATABASE_URL=postgresql+psycopg2://agentcare:agentcare@db:5432/agentcare

# ---- LLM / Agents ----
# Provider: anthropic | mock   (mock = deterministic, no API key; for tests/offline/CI)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=3

# ---- Document storage ----
# Local filesystem directory where uploaded patient documents are stored.
STORAGE_DIR=./storage
MAX_UPLOAD_MB=15

# ---- Seed / bootstrap ----
# Default password assigned to seeded demo accounts (synthetic data only).
SEED_DEFAULT_PASSWORD=AgentCare!2026
