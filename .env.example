# ============================================================================
# Root environment for docker-compose. Copy to `.env` (gitignored) and edit.
# The app runs WITHOUT an LLM key using the deterministic mock provider; set a
# real ANTHROPIC_API_KEY and LLM_PROVIDER=anthropic for genuine Claude reasoning.
# ============================================================================

# ---- Database (PostgreSQL container) ----
POSTGRES_USER=agentcare
POSTGRES_PASSWORD=agentcare
POSTGRES_DB=agentcare

# ---- Backend ----
ENVIRONMENT=development
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
SEED_DEFAULT_PASSWORD=AgentCare!2026

# ---- LLM / Agents ----
LLM_PROVIDER=mock            # anthropic | mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# ---- Frontend ----
# Host-facing backend URL baked into the browser bundle at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
